rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDoctor() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'doctor';
    }

    function isAssignedDoctor(patientId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(patientId))
        && get(/databases/$(database)/documents/users/$(patientId)).data.role == 'patient'
        && get(/databases/$(database)/documents/users/$(patientId)).data.doctorUid == request.auth.uid;
    }

    function isPatientAlert(alertData) {
      return isSignedIn()
        && alertData.patientId is string
        && request.auth.uid == alertData.patientId;
    }

    function isDoctorAlert(alertData) {
      return isSignedIn()
        && alertData.patientId is string
        && isAssignedDoctor(alertData.patientId)
        && (
          !(alertData.assignedDoctorId is string)
          || alertData.assignedDoctorId == request.auth.uid
        )
        && (
          !(alertData.doctorUid is string)
          || alertData.doctorUid == request.auth.uid
        );
    }

    function isPatientMeasurement(measurementData) {
      return isSignedIn()
        && measurementData.uid is string
        && request.auth.uid == measurementData.uid;
    }

    function isDoctorMeasurement(measurementData) {
      return isSignedIn()
        && measurementData.uid is string
        && isAssignedDoctor(measurementData.uid);
    }

    // User profile document: user can create and manage only their own profile.
    match /users/{userId} {
      allow create: if (
          isSelf(userId)
          && request.resource.data.role is string
        ) || (
          isSignedIn()
          && request.resource.data.role == 'patient'
          && request.resource.data.doctorUid == request.auth.uid
        );

      // READ: propriétaire OU médecin assigné OU docteur (pour chercher patients non assignés)
      allow read: if isSelf(userId)
        || (
          isSignedIn()
          && resource.data.role == 'patient'
          && resource.data.doctorUid == request.auth.uid
        )
        || (
          isDoctor()
          && resource.data.role == 'patient'
          && (
            !(resource.data.doctorUid is string)
            || resource.data.doctorUid == null
            || resource.data.doctorUid == ''
          )
        );

      // UPDATE: propriétaire OU médecin assigné OU docteur assignant patient non assigné
      allow update: if isSelf(userId)
        || (
          isSignedIn()
          && resource.data.role == 'patient'
          && resource.data.doctorUid == request.auth.uid
        )
        || (
          isDoctor()
          && resource.data.role == 'patient'
          && (
            !(resource.data.doctorUid is string)
            || resource.data.doctorUid == null
            || resource.data.doctorUid == ''
          )
          && request.resource.data.doctorUid == request.auth.uid
        );

      allow delete: if isSelf(userId);
    }

    // Measurements: patient can access own records, assigned doctor can read.
    match /measurements/{measurementId} {
      allow create: if isPatientMeasurement(request.resource.data);

      allow update: if isPatientMeasurement(resource.data)
        && isPatientMeasurement(request.resource.data);

      allow read: if isPatientMeasurement(resource.data)
        || isDoctorMeasurement(resource.data);

      allow delete: if isPatientMeasurement(resource.data);
    }

    // Alerts: patient can access their own alerts, assigned doctor can read/write.
    match /alerts/{alertId} {
      allow create: if isPatientAlert(request.resource.data)
        || isDoctorAlert(request.resource.data);

      allow read: if isPatientAlert(resource.data)
        || isDoctorAlert(resource.data);

      allow update: if (isPatientAlert(resource.data) || isDoctorAlert(resource.data))
        && (isPatientAlert(request.resource.data) || isDoctorAlert(request.resource.data));

      allow delete: if isPatientAlert(resource.data) || isDoctorAlert(resource.data);
    }

    // Conversations: participants can read/write, creation allowed for signed-in users
    match /conversations/{conversationId} {
      allow create: if isSignedIn();

      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isSignedIn()
          && request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(conversationId))
              .data.participants;
      }
    }

    // Notes: patient and doctor can read, doctor can create/update/delete
    match /notes/{noteId} {
      allow read: if isSignedIn() && (
        resource.data.patientId == request.auth.uid
        || resource.data.doctorUid == request.auth.uid
      );

      allow create: if isDoctor()
        && request.resource.data.doctorUid == request.auth.uid;

      allow update, delete: if isDoctor()
        && resource.data.doctorUid == request.auth.uid;
    }
  }
}
