' COUCHE ROUTER
' ═══════════════════════════════════════════
package "Router — lib/router/" #F1EFE8 {

  class AppRouter {
    + createAppRouter(authProvider, initialLocation): GoRouter
  }

  class RouteNames {
    {static} + splash: String
    {static} + login: String
    {static} + patientDashboard: String
    {static} + realtimeMonitoring: String
    {static} + patientHistory: String
    {static} + patientSettings: String
    {static} + relaxation: String
    {static} + doctorDashboard: String
    {static} + doctorPatientsList: String
    {static} + doctorAnalysis(id, date): String
    {static} + nightDetail(id, date): String
    {static} + accessDenied: String
    {static} + fixProfile: String
  }
}

' ═══════════════════════════════════════════
' RELATIONS — Héritage
' ═══════════════════════════════════════════
AuthProvider       --|> ChangeNotifier
UserProfileProvider --|> ChangeNotifier
MonitoringProvider  --|> ChangeNotifier
ThemeProvider      --|> ChangeNotifier
LocaleProvider     --|> ChangeNotifier

' ═══════════════════════════════════════════
' RELATIONS — Composition (a-un)
' ═══════════════════════════════════════════
AuthProvider        *-- FirebaseService
UserProfileProvider *-- FirebaseService
MonitoringProvider  *-- WebSocketService
MonitoringProvider  *-- MonitoringService
ThemeProvider       *-- SettingsService
LocaleProvider      *-- SettingsService
AlertService        *-- FirebaseService
PdfReportService    ..> ReportData

' ═══════════════════════════════════════════
' RELATIONS — Dépendances (utilise)
' ═══════════════════════════════════════════
LoginScreen              ..> AuthProvider      : lit role
LoginScreen              ..> FirebaseService   : signIn()
RealtimeMonitoringScreen ..> MonitoringProvider : startMonitoring()
RealtimeMonitoringScreen ..> AuthProvider       : lit user.uid
RealtimeMonitoringScreen ..> FirebaseService    : saveMonitoringSession()
DoctorAnalysisScreen     ..> FirebaseService   : mesures/notes
DoctorPatientsListScreen ..> FirebaseService   : streamDoctorPatients()

FirebaseService ..> Patient   : persiste
FirebaseService ..> Alert     : persiste
FirebaseService ..> Message   : persiste

AppRouter ..> AuthProvider : refreshListenable
AppRouter ..> RouteNames

@enduml