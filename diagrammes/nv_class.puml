package "View — lib/screens/" #E6F1FB {

  package "screens/patient/" {
    class DashboardPatientScreen
    class RealtimeMonitoringScreen {
      - _monitoringService: MonitoringService
      - _firebaseService: FirebaseService
      - _isMonitoring: bool
      - _live: _EspData?
      - _history: List<_EspData>
      + _startMonitoring(): void
      + _stopMonitoring(): Future<void>
      + _onData(esp: _EspData): void
    }
    class PatientHistoryScreen
    class PatientChatbotScreen
    class PatientSettingsScreen
  }

  package "screens/doctor/" {
    class DashboardDoctorScreen
    class DoctorAnalysisScreen
    class DoctorPatientsListScreen
    class DoctorChatbotScreen
    class DoctorReportsScreen
    class DoctorSettingsScreen
  }

  package "screens/auth/" {
    class LoginScreen {
      - _firebaseService: FirebaseService
      - _selectedRole: String?
      - _isLoading: bool
      + _login(): Future<void>
    }
    class SplashScreen
  }

  package "lib/widgets/" {
    class PatientChatbotFAB
    class DoctorChatbotFAB
  }
}

